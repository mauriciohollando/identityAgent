FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    PORT=8090 \
    TRANSACTION_LOG_DB_PATH=/data/transaction_log.db

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN mkdir -p /data
COPY src/transaction_log ./src/transaction_log

EXPOSE 8090

CMD ["sh", "-c", "exec uvicorn transaction_log.app:app --host 0.0.0.0 --port ${PORT:-8090}"]
