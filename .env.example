# Copy to .env or set in Cloud Run. Not auto-loaded.

# --- Gemini (A2A LLM path) ---
# GOOGLE_API_KEY=

# --- Public URL (agent card) ---
# AGENT_PUBLIC_BASE_URL=https://your-service.run.app/

# --- Security ---
# AUDITOR_TOKEN_SECRET=

# --- Identity (multi-registry: comma-separated bases) ---
# IDENTITY_REGISTRY_URLS=https://registry-a.example.com,https://registry-b.example.com
# IDENTITY_REGISTRY_URL=http://127.0.0.1:8091
#   (bundled registry: PYTHONPATH=src uvicorn identity_registry.app:app --port 8091)
# IDENTITY_REGISTRY_BEARER_TOKEN=
#   (same as REGISTRY_SERVICE_API_KEY when the registry enforces auth)
# IDENTITY_REGISTRY_QUORUM=all
#   all | any | majority

# --- Bundled identity registry process ---
# IDENTITY_REGISTRY_DB_PATH=./data/identity_registry.db
# REGISTRY_SERVICE_API_KEY=
# REGISTRY_ADMIN_API_KEY=
#   (Bearer for POST /v1/admin/agents/{id}/attest/operator)
# PARTNER_ATTESTATION_TOKEN=
#   (X-Partner-Attestation-Token for partner attest webhook)
# REGISTRY_REQUIRE_KYC=0
# REGISTRY_REQUIRE_SIGNING_KEY=0

# --- Performance / MCP (multi-source: comma-separated) ---
# MCP_SERVER_URLS=https://logs-a.example.com,https://logs-b.example.com
# MCP_SERVER_BASE_URL=http://127.0.0.1:8090
#   (local log service: PYTHONPATH=src uvicorn transaction_log.app:app --port 8090)
# MCP_SERVER_BEARER_TOKEN=
# TRUST_AUDITOR_ALLOW_PERFORMANCE_STUB=
#   Optional override. With AP2_MODE=live, synthetic performance when MCP is unset is OFF (returns no data + REVIEW_REQUIRED).
#   Set true only for a deliberate demo with live billing—production should always set MCP_SERVER_*.
#   (must match LOG_SERVICE_API_KEY on the log service when auth is enabled)

# --- Transaction log service (optional dedicated process) ---
# TRANSACTION_LOG_DB_PATH=./data/transaction_log.db
# LOG_AGGREGATION_WINDOW_DAYS=90
# LOG_SERVICE_API_KEY=
# PERF_AGGREGATION=median
#   median | mean
# PERF_SOURCE_DISAGREEMENT_THRESHOLD=0.25

# --- Tiers ---
# VERIFICATION_TIER=standard
# MIN_SAMPLE_SIZE_STANDARD=5
# MIN_SAMPLE_SIZE_ENTERPRISE=30

# --- AP2 / payments ledger ---
AP2_MODE=stub
# AP2_BILLING_MODE=per_call
#   per_call | credits | credits_or_gateway | subscription | subscription_or_gateway
# VERIFICATION_FEE_USD=0.10
# PAYMENT_CURRENCY=USD
# PAYMENT_LEDGER_DB_PATH=./data/payment_ledger.db
# PAYMENTS_PERSIST_STUB=false
# AP2_GATEWAY_URL=https://your-treasury.example.com
# AP2_GATEWAY_TOKEN=
# AP2_GATEWAY_MANDATES_PATH=/v1/mandates
# AP2_GATEWAY_JSON_BODY=
# AP2_IDEMPOTENCY_HEADER=Idempotency-Key
# AP2_RESPONSE_AUTHORIZED_FIELD=authorized
# AP2_RESPONSE_MANDATE_ID_FIELD=mandate_id
# AP2_HTTP_MAX_RETRIES=3
# AP2_HTTP_RETRY_BACKOFF_SEC=0.5
# AP2_GATEWAY_REFUND_PATH=/v1/mandates/{mandate_id}/refund
# PAYMENT_WEBHOOK_SECRET=
# PAYMENT_OPS_API_KEY=
#   (Bearer for GET /internal/payments/summary, POST /internal/payments/credits)
# AP2_SUBSCRIPTION_TIERS_JSON={"starter":{"included_calls":500,"period_days":30},"growth":{"included_calls":5000,"period_days":30},"scale":{"included_calls":30000,"period_days":30}}

# --- Stripe adapter (if you run your own AP2 gateway) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_ADAPTER_CLIENT_TOKEN=
# STRIPE_ADAPTER_OPS_TOKEN=
# STRIPE_ADAPTER_DB_PATH=./data/stripe_adapter.db
# AUDITOR_WEBHOOK_URL=http://127.0.0.1:8080/internal/webhooks/payment
# PAYMENT_WEBHOOK_SECRET=  (same as auditor; adapter signs subscription-sync payloads)
# STRIPE_PRICE_TO_TIER_JSON={"price_xxx":"starter","price_yyy":"growth"}
# AUDITOR_SUBSCRIPTION_SYNC_URL=http://127.0.0.1:8080/internal/webhooks/subscription-sync

# --- Ops ---
# RATE_LIMIT_PER_MINUTE=120
# DISPUTES_DB_PATH=./data/disputes.db
# DISPUTE_FILING_URL=https://your-service.run.app/v1/disputes

# AUDITOR_LLM_MODEL=gemini-2.5-flash
