FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    PORT=8092 \
    STRIPE_ADAPTER_DB_PATH=/data/stripe_adapter.db

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN mkdir -p /data
COPY src/stripe_adapter ./src/stripe_adapter

EXPOSE 8092

CMD ["sh", "-c", "exec uvicorn stripe_adapter.app:app --host 0.0.0.0 --port ${PORT:-8092}"]

