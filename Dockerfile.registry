FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    PORT=8091 \
    IDENTITY_REGISTRY_DB_PATH=/data/identity_registry.db

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

RUN mkdir -p /data
COPY src/identity_registry ./src/identity_registry

EXPOSE 8091

CMD ["sh", "-c", "exec uvicorn identity_registry.app:app --host 0.0.0.0 --port ${PORT:-8091}"]
